{
    "name": "DHQG",
    "private": true,
    "version": "1.1.1",
    "description": "NestJS Starter REST API Repository",
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "prestart:dev": "rimraf dist",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/src/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
        "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "lintsrc": "eslint src/",
        "test": "jest --runInBand",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
        "migration:generate": "ts-node ./node_modules/typeorm/cli.js migration:generate -n",
        "migration:run": "ts-node ./node_modules/typeorm/cli.js migration:run",
        "migration:revert": "ts-node ./node_modules/typeorm/cli.js migration:revert",
        "migration:prod": "node scripts/migrate-production.bat",
        "deploy:prod": "bash deploy-production.sh",
        "doc:serve": "npx compodoc -p tsconfig.json -w -s -r 8001",
        "doc:generate": "npx compodoc -p tsconfig.json",
        "pre-commit": "lint-staged",
        "debug": "yarn start:dev",
        "prepare": "husky install"
    },
    "lint-staged": {
        "**/*.ts": [
            "eslint --fix"
        ]
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.940.0",
        "@aws-sdk/lib-storage": "^3.940.0",
        "@nestjs-modules/mailer": "^2.0.2",
        "@nestjs/axios": "^0.0.8",
        "@nestjs/common": "^8.0.6",
        "@nestjs/config": "^1.0.1",
        "@nestjs/core": "8.3.1",
        "@nestjs/elasticsearch": "^10.0.1",
        "@nestjs/jwt": "^8.0.1",
        "@nestjs/passport": "^8.2.2",
        "@nestjs/platform-express": "^8.0.6",
        "@nestjs/schedule": "^2.2.0",
        "@nestjs/swagger": "^5.0.9",
        "@nestjs/typeorm": "8.0.2",
        "axios": "^1.12.2",
        "bcrypt": "^5.0.1",
        "bull-board": "^1.1.2",
        "class-transformer": "0.4.0",
        "class-validator": "^0.13.1",
        "crypto-js": "^4.2.0",
        "docxtemplater": "^3.43.1",
        "dotenv": "^16.0.1",
        "exceljs": "^4.4.0",
        "express-basic-auth": "^1.2.1",
        "express-session": "^1.17.3",
        "fs-extra": "^11.2.0",
        "handlebars": "^4.7.8",
        "http": "0.0.1-security",
        "https": "^1.0.0",
        "moment": "^2.29.3",
        "mysql": "^2.18.1",
        "mysql2": "^2.3.3",
        "nodemailer": "^7.0.10",
        "passport": "^0.6.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "pm2": "^5.3.0",
        "reflect-metadata": "^0.1.13",
        "rimraf": "^3.0.2",
        "rxjs": "^7.3.0",
        "swagger-ui-express": "^4.5.0",
        "typeorm": "^0.2.37",
        "uuid": "^13.0.0",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@compodoc/compodoc": "^1.1.14",
        "@nestjs/cli": "^8.1.1",
        "@nestjs/testing": "^8.0.6",
        "@types/bcrypt": "^5.0.0",
        "@types/express": "^4.17.23",
        "@types/jest": "^27.0.1",
        "@types/multer": "^2.0.0",
        "@types/node": "^20.11.0",
        "@types/nodemailer": "^7.0.3",
        "@types/passport-jwt": "^3.0.6",
        "@types/passport-local": "^1.0.34",
        "@types/supertest": "^2.0.11",
        "@typescript-eslint/eslint-plugin": "^4.33.0",
        "@typescript-eslint/parser": "^4.30.0",
        "eslint": "^7.32.0",
        "eslint-config-prettier": "^8.3.0",
        "eslint-plugin-import": "^2.25.4",
        "eslint-plugin-simple-import-sort": "^7.0.0",
        "husky": "^8.0.0",
        "jest": "^27.5.1",
        "jest-sonar-reporter": "^2.0.0",
        "lint-staged": "^11.1.2",
        "prettier": "^2.5.1",
        "supertest": "^6.2.2",
        "ts-jest": "^27.1.3",
        "ts-node": "^10.2.1",
        "tsconfig-paths": "^3.11.0",
        "typescript": "^4.4.2"
    },
    "jest": {
        "testResultsProcessor": "jest-sonar-reporter",
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".spec.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coveragePathIgnorePatterns": [
            ".module.ts$"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
